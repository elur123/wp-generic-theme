{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "color": {
      "palette": [
        { "slug": "primary",         "name": "Coral",        "color": "#f25f5a" },
        { "slug": "primary-light",   "name": "Coral Light",  "color": "#fde8e8" },
        { "slug": "primary-dark",    "name": "Coral Dark",   "color": "#d94441" },
        { "slug": "secondary",       "name": "Gold",         "color": "#C9A96E" },
        { "slug": "secondary-light", "name": "Gold Light",   "color": "#F5ECD9" },
        { "slug": "neutral-50",      "name": "Off White",    "color": "#FAFAFA" },
        { "slug": "neutral-100",     "name": "Light Gray",   "color": "#F4F5F4" },
        { "slug": "neutral-200",     "name": "Border",       "color": "#E5E7E6" },
        { "slug": "neutral-700",     "name": "Body Text",    "color": "#3A3D3C" },
        { "slug": "neutral-900",     "name": "Headings",     "color": "#1A1C1B" },
        { "slug": "white",           "name": "White",        "color": "#FFFFFF" }
      ],
      "gradients": [],
      "duotone": []
    },
    "typography": {
      "fontFamilies": [
        {
          "slug": "heading",
          "name": "Playfair Display",
          "fontFamily": "\"Playfair Display\", Georgia, serif"
        },
        {
          "slug": "body",
          "name": "Inter",
          "fontFamily": "Inter, system-ui, -apple-system, sans-serif"
        }
      ],
      "fontSizes": [
        { "slug": "sm",   "name": "Small",    "size": "0.875rem" },
        { "slug": "base", "name": "Base",     "size": "1rem" },
        { "slug": "lg",   "name": "Large",    "size": "clamp(1.125rem, 2vw, 1.25rem)" },
        { "slug": "xl",   "name": "X-Large",  "size": "clamp(1.25rem, 2.5vw, 1.5rem)" },
        { "slug": "2xl",  "name": "2X-Large", "size": "clamp(1.5rem, 3vw, 2rem)" },
        { "slug": "3xl",  "name": "3X-Large", "size": "clamp(2rem, 4vw, 2.75rem)" },
        { "slug": "4xl",  "name": "4X-Large", "size": "clamp(2.5rem, 5vw, 3.5rem)" }
      ],
      "dropCap": false
    },
    "layout": {
      "contentSize": "980px",
      "wideSize": "1200px"
    },
    "spacing": {
      "spacingSizes": [
        { "slug": "sm",  "name": "Small",   "size": "1rem" },
        { "slug": "md",  "name": "Medium",  "size": "2rem" },
        { "slug": "lg",  "name": "Large",   "size": "4rem" },
        { "slug": "xl",  "name": "X-Large", "size": "6rem" }
      ]
    },
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true
  },
  "styles": {
    "color": {
      "background": "#FAFAFA",
      "text": "#3A3D3C"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--body)",
      "fontSize": "var(--wp--preset--font-size--base)",
      "lineHeight": "1.75"
    },
    "elements": {
      "h1": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontSize": "var(--wp--preset--font-size--4xl)",
          "lineHeight": "1.2"
        }
      },
      "h2": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontSize": "var(--wp--preset--font-size--3xl)",
          "lineHeight": "1.25"
        }
      },
      "h3": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontSize": "var(--wp--preset--font-size--2xl)",
          "lineHeight": "1.3"
        }
      },
      "h4": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontSize": "var(--wp--preset--font-size--xl)",
          "lineHeight": "1.35"
        }
      },
      "h5": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontSize": "var(--wp--preset--font-size--lg)"
        }
      },
      "h6": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontSize": "var(--wp--preset--font-size--base)"
        }
      },
      "button": {
        "color": {
          "background": "#2D7D7A",
          "text": "#FFFFFF"
        },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--body)",
          "fontWeight": "600"
        },
        "border": { "radius": "9999px" }
      }
    }
  }
}
